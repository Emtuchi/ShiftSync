// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssignmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum SwapType {
  FULL
  PARTIAL
}

enum SwapStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

// --------------------
// Models
// --------------------

model User {
  id             String               @id @default(uuid())
  email          String               @unique
  name           String?
  password       String
  role           UserRole             @default(STAFF)
  skills         StaffSkill[]
  certifications StaffCertification[]
  assignments    ShiftAssignment[]
  swapsRequested SwapRequest[]        @relation("TargetSwapStaff")
  notifications  Notification[]
  availability   AvailabilityWindow[]

  // Many-to-many relation to Location
  managedLocations Location[] @relation("ManagerLocations")
}

model Location {
  id      String  @id @default(uuid())
  name    String
  address String
  shifts  Shift[]

  // Many-to-many relation to User
  managers User[] @relation("ManagerLocations")

  certifications StaffCertification[]
  createdAt      DateTime             @default(now())
}

model Skill {
  id               String   @id @default(uuid())
  name             String   
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relation to Shift
  requiredForShift Shift[]       @relation("ShiftRequiredSkills")
  staffSkills      StaffSkill[]
}

model StaffSkill {
  id      String @id @default(uuid())
  staff   User   @relation(fields: [staffId], references: [id])
  staffId String
  skill   Skill  @relation(fields: [skillId], references: [id])
  skillId String
}

model StaffCertification {
  id         String   @id @default(uuid())
  staff      User     @relation(fields: [staffId], references: [id])
  staffId    String
  location   Location @relation(fields: [locationId], references: [id])
  locationId String
}

model Shift {
  id              String            @id @default(uuid())
  location        Location          @relation(fields: [locationId], references: [id])
  locationId      String
  startTime       DateTime
  endTime         DateTime
  requiredSkill   Skill             @relation("ShiftRequiredSkills", fields: [requiredSkillId], references: [id])
  requiredSkillId String
  headcount       Int
  published       Boolean           @default(false)
  assignments     ShiftAssignment[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  status          ShiftStatus       @default(DRAFT)
}

model ShiftAssignment {
  id          String           @id @default(uuid())
  shift       Shift            @relation(fields: [shiftId], references: [id])
  shiftId     String
  staff       User             @relation(fields: [staffId], references: [id])
  staffId     String
  status      AssignmentStatus @default(PENDING) // PENDING, CONFIRMED, CANCELLED
  swapRequest SwapRequest?     @relation("SwapOriginalAssignment")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([shiftId, staffId])
}

model SwapRequest {
  id                   String          @id @default(uuid())
  type                 SwapType
  originalAssignment   ShiftAssignment @relation("SwapOriginalAssignment", fields: [originalAssignmentId], references: [id])
  originalAssignmentId String          @unique
  targetStaff          User?           @relation("TargetSwapStaff", fields: [targetStaffId], references: [id])
  targetStaffId        String?
  status               SwapStatus      @default(PENDING)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model AvailabilityWindow {
  id        String   @id @default(uuid())
  staff     User     @relation(fields: [staffId], references: [id])
  staffId   String
  startTime DateTime
  endTime   DateTime
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
